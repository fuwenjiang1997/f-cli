{
  "name": "f-cli",
  "version": "1.0.0",
  "description": "f-cli 脚手架",
  "author": "fuwenjiang",
  "main": "index.js",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "dev:cli": "turbo run dev @f-cli/cli",
    "build:cli": "turbo build @f-cli/cli",
    "lint": "eslint \"{packages,apps}/**/*.{js,jsx,ts,tsx}\" --fix",
    "spellcheck": "cspell lint --dot --gitignore --color --cache --show-suggestions \"(packages|apps)/**/*.@(html|js|cjs|mjs|ts|tsx|css|scss|md)\"",
    "prepare": "husky",
    "commit": "git-cz"
  },
  "dependencies": {},
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "10.0.1",
    "commitizen": "4.3.1",
    "cspell": "10.0.0",
    "cz-git": "1.12.0",
    "eslint": "10.2.0",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "tsup": "8.5.1",
    "turbo": "2.9.5",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "madge": "8.0.0",
    "eslint-plugin-simple-import-sort": "13.0.0"
  },
  "packageManager": "pnpm@10.24.0",
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git",
      "useEmoji": true
    }
  }
}
